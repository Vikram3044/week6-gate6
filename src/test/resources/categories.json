[
  {"name":"Assertion Failures","matchedStatuses":["failed"],"messageRegex":".*(AssertionFailedError|AssertionError).*"},
  {"name":"UI Automation Issues","matchedStatuses":["broken","failed"],"messageRegex":".*NoSuchElementException.*"},
  {"name":"Database Issues","matchedStatuses":["broken","failed"],"messageRegex":".*SQLException.*"},
  {"name":"Configuration Issues","matchedStatuses":["broken","failed"],"messageRegex":".*IllegalArgumentException.*"},
  {"name":"Infrastructure Issues","matchedStatuses":["broken"],"messageRegex":".*(Docker|Testcontainers|Connection).*"},
  {"name":"Other Failures","matchedStatuses":["failed","broken","unknown"]}
]
